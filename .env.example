# Скопируйте в .env при необходимости: copy .env.example .env

# UID/GID пользователя app в образе (как при docker build)
APP_UID=1000
APP_GID=1000

# Имя файла в packages/
CURSOR_DEB_FILE=cursor_3.5.17_amd64.deb

# 1 — Cursor запускается сам при старте контейнера
AUTOSTART_CURSOR=1

# 1 — переустановка Cursor из /packages/ при каждом старте
CURSOR_AUTO_UPDATE=0

# Разрешение VNC / Xvfb (пересоздайте контейнер после смены)
VNC_WIDTH=1920
VNC_HEIGHT=1080
# VNC_DEPTH=24

# SSH: ./ssh/ на хосте → /home/app/.ssh в контейнере

# Клавиатура в VNC (после пересборки/перезапуска)
# XKB_LAYOUT=us,ru
# XKB_OPTIONS=grp:alt_shift_toggle
# Альтернатива: одна строка (имеет приоритет над VNC_WIDTH/VNC_HEIGHT)
# VNC_RESOLUTION=2560x1440
